---
export const prerender = true

import { reader, assetUrl } from '../lib/reader'
import ServicePageTemplate from '../components/ServicePageTemplate.astro'
import SocialFeed from '../components/SocialFeed.astro'

const page = await reader.collections.servicePages.read('redes-sociais')
if (!page) throw new Error('Conteúdo da página "redes-sociais" não encontrado')

const accounts = (await reader.collections.social.all())
  .map((e) => ({ id: e.slug, ...e.entry }))
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))

// Mosaico de fundo do hero: thumbs (imagem ou poster) intercalados entre as contas.
const galleries = accounts.map((a) =>
  (a.posts ?? [])
    .map((p) => assetUrl(p.type === 'video' ? p.poster : p.image, '/portfolio/social/'))
    .filter(Boolean) as string[],
)
const heroMosaic: string[] = []
const maxLen = Math.max(0, ...galleries.map((g) => g.length))
for (let i = 0; i < maxLen; i++) {
  for (const g of galleries) if (g[i]) heroMosaic.push(g[i])
}
---

<ServicePageTemplate
  seoTitle={page.seoTitle}
  description={page.description}
  eyebrow={page.eyebrow}
  heroTitle={page.heroTitle}
  heroSubtitle={page.heroSubtitle}
  whatTitle={page.whatTitle}
  whatBody={page.whatBody}
  deliverables={page.deliverables}
  forWhom={page.forWhom}
  heroBgImages={heroMosaic}
  heroCta={{ label: 'Ver as contas', href: '#contas' }}
>
  {accounts.length > 0 && (
    <SocialFeed
      accounts={accounts}
      eyebrow="Cases"
      title="Contas que gerenciamos"
      description="Conteúdo de feed e reels produzido pela Chronos. Clique numa conta para ver todo o trabalho — fotos e vídeos daquela marca."
    />
  )}
</ServicePageTemplate>
