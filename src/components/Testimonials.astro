---
import { reader } from '../lib/reader'

const entries = await reader.collections.testimonials.all()
const items = entries
  .map((e) => ({ id: e.slug, ...e.entry }))
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))

const quotes = items.filter((t) => !t.video && t.quote)

const stars = (n: number | undefined) => Math.max(0, Math.min(5, n ?? 5))
---

<section class="bg-ink py-24 sm:py-28">
  <div class="max-w-8xl mx-auto px-5 sm:px-8">
    <div data-reveal class="reveal mb-12">
      <p class="eyebrow text-xs font-semibold uppercase text-cyan mb-3">Depoimentos</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold">O que dizem sobre a Chronos</h2>
      <p class="mt-2 text-mut max-w-xl">Resultados que viram relação — e relação que vira recomendação.</p>
    </div>

    {quotes.length > 0 && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {quotes.map((t) => (
          <figure data-reveal class="reveal rounded-2xl bg-card border border-line p-7 flex flex-col">
            <div class="flex gap-0.5 text-cyan mb-4" aria-label={`${stars(t.rating)} de 5 estrelas`}>
              {Array.from({ length: stars(t.rating) }).map(() => (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.8 5.9 21l1.4-6.8L2.2 9.5l6.9-.8z"/></svg>
              ))}
            </div>
            <blockquote class="text-sm text-white/85 leading-relaxed flex-1">“{t.quote}”</blockquote>
            <figcaption class="mt-5 pt-4 border-t border-white/10">
              <span class="block font-bold text-sm">{t.author}</span>
              {t.company && <span class="block text-xs text-mut mt-0.5">{t.company}</span>}
            </figcaption>
          </figure>
        ))}
      </div>
    )}
  </div>
</section>
