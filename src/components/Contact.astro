---
import { reader } from '../lib/reader'
import ContactForm from './ContactForm.tsx'
import FloatingIcon from './FloatingIcon.astro'

const contact = await reader.singletons.contact.read()
const WA_BR = contact?.whatsBrUrl ?? 'https://wa.me/5545999692993'
const WA_US = contact?.whatsUsUrl ?? 'https://wa.me/17723013263'
---

<section id="contato" class="bg-panel relative overflow-hidden py-24 sm:py-28 border-t border-white/5">
  <FloatingIcon src="/icones/cursor.png" class="left-[3%] top-[10%] w-20 lg:w-28" variant="c" speed={0.12} opacity={0.36} />
  <div class="max-w-8xl mx-auto px-5 sm:px-8 grid md:grid-cols-2 gap-12 relative z-10">
    <div data-reveal class="reveal">
      <h2 class="text-3xl sm:text-5xl font-extrabold leading-tight">
        {contact?.title}
      </h2>
      <p class="mt-5 text-mut max-w-md leading-relaxed">
        {contact?.description}
      </p>

      <div class="mt-8 space-y-4">
        <div class="flex items-start gap-3 text-sm text-mut">
          <svg class="w-4 h-4 text-cyan mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{contact?.locations}</span>
        </div>
        <div class="flex items-center gap-3 text-sm text-mut">
          <svg class="w-4 h-4 text-cyan shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.64A2 2 0 012 .18h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.18v2.74z"/></svg>
          <span>
            <a href={WA_US} class="hover:text-cyan transition">{contact?.whatsUsLabel}</a>
            {' · '}
            <a href={WA_BR} class="hover:text-cyan transition">{contact?.whatsBrLabel}</a>
          </span>
        </div>
        <div class="flex items-center gap-3 text-sm text-mut">
          <svg class="w-4 h-4 text-cyan shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href={`mailto:${contact?.email}`} class="hover:text-cyan transition">{contact?.email}</a>
        </div>
      </div>
    </div>

    <div data-reveal class="reveal">
      <ContactForm client:load />
    </div>
  </div>
</section>
