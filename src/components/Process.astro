---
import { reader } from '../lib/reader'

const entries = await reader.collections.processSteps.all()
const processSteps = entries
  .map(e => e.entry)
  .sort((a, b) => (a.number ?? '').localeCompare(b.number ?? ''))

const home = await reader.singletons.home.read()
const h = home?.processHeader
---

<section class="py-24 sm:py-28">
  <div class="max-w-8xl mx-auto px-5 sm:px-8">
    <div data-reveal class="reveal">
      <p class="eyebrow text-xs font-semibold uppercase text-cyan mb-3">{h?.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold">{h?.title}</h2>
      <p class="mt-2 text-mut max-w-xl">{h?.description}</p>
    </div>

    <div class="mt-16 relative proc-timeline" style={`--total: ${processSteps.length}`}>
      <div class="hidden md:block absolute top-2 left-0 right-0 h-px bg-white/10"></div>
      <div class="proc-pulse hidden md:block absolute top-2"></div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-6">
        {processSteps.map((step, i) => (
          <div data-reveal class="reveal relative">
            <span class="proc-bead block w-4 h-4 rounded-full bg-cyan mb-6" style={`--i: ${i}`}></span>
            <span class="text-3xl font-extrabold text-cyan">{step.number}</span>
            <h3 class="mt-3 font-bold uppercase text-sm tracking-wide">{step.title}</h3>
            <p class="mt-2 text-sm text-mut leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .proc-timeline { --cycle: 8s; }

  /* Cada bolinha acende em cascata, conforme o pulso chega nela. */
  .proc-bead {
    transform-origin: center;
    box-shadow: 0 0 0 4px rgba(51, 204, 255, 0.15);
    animation: bead-pulse var(--cycle) ease-in-out infinite;
    animation-delay: calc(var(--i) * var(--cycle) / var(--total));
  }
  @keyframes bead-pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 4px rgba(51, 204, 255, 0.15); }
    12%      { transform: scale(1.4); box-shadow: 0 0 0 5px rgba(51, 204, 255, 0.28), 0 0 22px 5px rgba(51, 204, 255, 0.6); }
    36%      { transform: scale(1); box-shadow: 0 0 0 4px rgba(51, 204, 255, 0.15); }
  }

  /* Pulso de luz que viaja pela linha, da primeira à última fase. */
  .proc-pulse {
    width: 90px;
    height: 2px;
    left: 0;
    background: linear-gradient(90deg, transparent, #5cd8ff 50%, transparent);
    box-shadow: 0 0 14px 2px rgba(51, 204, 255, 0.7);
    transform: translateX(-50%);
    animation: pulse-travel var(--cycle) linear infinite;
  }
  @keyframes pulse-travel {
    0%   { left: 0;    opacity: 0; }
    8%   { opacity: 1; }
    90%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .proc-bead { animation: none; box-shadow: 0 0 0 4px rgba(51, 204, 255, 0.15); }
    .proc-pulse { display: none; }
  }
</style>
